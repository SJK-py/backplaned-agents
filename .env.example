# Copy to `.env` and adjust. The bp_router Settings model picks these up
# at startup (env_prefix=ROUTER_).
#
# NOTE: do NOT `set -a; . ./.env` from a shell — values containing `{`,
# `}`, or `$` (like ROUTER_FILE_STORE_OPTIONS) get re-interpreted by
# bash. pydantic-settings reads the file directly via dotenv, so just
# point bp-router at it (it auto-discovers `.env` in the working dir).

# --- Required ---
ROUTER_DB_URL=postgresql://postgres:bp@localhost:5432/bp_router
ROUTER_PUBLIC_URL=http://localhost:8000

# Generate fresh values: `openssl rand -base64 32` for each.
ROUTER_JWT_SECRET=replace-me-with-32-bytes-of-randomness
ROUTER_ADMIN_SESSION_SECRET=replace-me-with-32-bytes-of-randomness

# --- First-admin bootstrap (first boot only) ---
# When both are set AND no user with this email exists, the lifespan
# inserts an admin user on startup so you can log into /admin
# (`POST /v1/admin/users` requires an existing admin — chicken-and-egg
# without this). Idempotent — safe to leave set across restarts.
#
# Use a real-looking domain (NOT `.test` / `.example.invalid` etc.) —
# Pydantic's EmailStr rejects "special-use" TLDs and the auth login
# would reject this email even though the bootstrap accepted it.
# RFC 2606 reserves `example.com` for documentation/testing; that's
# the safest choice for a dev fixture.
# ROUTER_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# ROUTER_BOOTSTRAP_ADMIN_PASSWORD=replace-me-with-a-strong-password

# --- Common ---
ROUTER_DEPLOYMENT_ENV=dev
ROUTER_LOG_LEVEL=INFO

# --- Optional infrastructure ---
# ROUTER_REDIS_URL=redis://localhost:6379/0
# ROUTER_FILE_STORE=local
# ROUTER_FILE_STORE_OPTIONS={"path": "./proxyfiles"}

# --- Optional observability ---
# ROUTER_OTEL_ENDPOINT=http://localhost:4318/v1/traces

# --- LLM provider keys (resolved by secret_ref:// when used) ---
# GEMINI_API_KEY=...
# ANTHROPIC_API_KEY=...
# OPENAI_API_KEY=...

# --- Agent-side env (used by bp_sdk) ---
# AGENT_ROUTER_URL=ws://localhost:8000/v1/agent
# AGENT_INVITATION_TOKEN=...   # one-shot from POST /v1/admin/invitations
# AGENT_STATE_DIR=./agent_state
