# Environment-variable reference for backplaned-agents.
#
# Three components read their config from the environment, each with its
# own prefix:
#   ROUTER_*  — the Backplaned router        (bp_router; auto-discovers ./.env)
#   AGENT_*   — every agent's SDK runtime    (bp_sdk)
#   SUITE_*   — the agent suite              (bp_agents)
# plus provider API keys (GEMINI_API_KEY, …) the router resolves for presets.
#
# Copy to `.env` and adjust. The router auto-loads `./.env` (ROUTER_*).
# The suite agents and SDK read SUITE_* / AGENT_* from their process
# environment — export the ones you change (scripts/run-suite.sh launches
# the agents in your current shell). Every var below shows its DEFAULT;
# uncomment only what you need to override.
#
# CAUTION: do NOT `set -a; . ./.env` blindly — ROUTER_FILE_STORE_OPTIONS
# contains `{ }` that bash would mangle. The router reads the file directly
# via dotenv. The SUITE_*/AGENT_* values below are plain strings, safe to export.


# ===========================================================================
# Router (ROUTER_*)  — see docs/backplaned/deployment.md for the complete list
# ===========================================================================

# --- Required ---
ROUTER_DB_URL=postgresql://postgres:bp@localhost:5432/bp_router
ROUTER_PUBLIC_URL=http://localhost:8000
# Generate fresh: `openssl rand -base64 32` for each.
ROUTER_JWT_SECRET=replace-me-with-32-bytes-of-randomness
ROUTER_ADMIN_SESSION_SECRET=replace-me-with-32-bytes-of-randomness

# --- First-admin bootstrap (first boot only; idempotent) ---
# Use a real-looking domain — Pydantic EmailStr rejects special-use TLDs
# (.test/.invalid). RFC 2606 reserves example.com for this.
# ROUTER_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# ROUTER_BOOTSTRAP_ADMIN_PASSWORD=replace-me-with-a-strong-password

# --- Common ---
ROUTER_DEPLOYMENT_ENV=dev
ROUTER_LOG_LEVEL=INFO

# --- OIDC / SSO for the webapp (optional; off by default) ---
# See docs/design/oidc-webapp.md. The router is the OIDC relying party.
# ROUTER_OIDC_ENABLED=false
# ROUTER_OIDC_ISSUER=https://auth.example.com           # OP base URL (https)
# ROUTER_OIDC_CLIENT_ID=backplaned-webapp
# ROUTER_OIDC_CLIENT_SECRET=env://OIDC_CLIENT_SECRET    # raw value or secret_ref
# ROUTER_OIDC_SCOPES=openid email profile groups
# ROUTER_OIDC_ALLOWED_REDIRECT_URIS=["https://app.example.com/auth/sso/callback"]
# ROUTER_OIDC_JIT_PROVISIONING=true                     # create users on first login
# ROUTER_OIDC_DEFAULT_LEVEL=tier1
# ROUTER_OIDC_GROUP_TO_LEVEL={"admins":"admin","staff":"tier0"}
# ROUTER_OIDC_ALLOWED_GROUPS=[]                         # non-empty → require membership
# ROUTER_OIDC_AUTO_LINK_BY_VERIFIED_EMAIL=false         # DANGER — see design doc §6

# --- Optional infrastructure / observability ---
# ROUTER_VALKEY_URL=redis://localhost:6379/0        # omitted → per-process fallback
# ROUTER_FILE_STORE=local                           # local | s3
# ROUTER_FILE_STORE_OPTIONS={"path": "./router_files"}   # local backend dir (default)
# ROUTER_OTEL_ENDPOINT=http://localhost:4318/v1/traces
# ROUTER_SHUTDOWN_GRACE_S=25     # uvicorn graceful-shutdown wait; keep below the
#                                # container stop_grace_period (30s in prod compose)

# --- LLM provider keys (a preset's api_key_ref, e.g. env://GEMINI_API_KEY) ---
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=


# ===========================================================================
# Agent SDK (AGENT_*)  — per-agent runtime; set per process / compose service
# ===========================================================================

# AGENT_ROUTER_URL=ws://localhost:8000/v1/agent     # router WebSocket
# AGENT_STATE_DIR=./agent_state                     # persists credentials.json
# AGENT_INVITATION_TOKEN=                           # one-shot onboarding token
# AGENT_AUTH_TOKEN=                                 # pre-issued JWT (alt to invite)
# AGENT_LOG_LEVEL=INFO
# Connection tuning (rarely changed):
# AGENT_PENDING_RESULTS_TIMEOUT_S=60
# AGENT_PENDING_ACKS_TIMEOUT_S=30
# AGENT_RECONNECT_MAX_BACKOFF_S=30


# ===========================================================================
# Suite (SUITE_*)  — bp_agents configuration
# ===========================================================================

# --- Suite database (the suite's own Postgres) ---
SUITE_DATABASE_URL=postgresql://postgres:bp@127.0.0.1:5432/bp_suite
# SUITE_DB_POOL_MIN_SIZE=1
# SUITE_DB_POOL_MAX_SIZE=10
# SUITE_DB_STATEMENT_TIMEOUT_MS=30000
# Optional. When set, the channel's per-session turn lock becomes a
# DISTRIBUTED lock (Valkey) instead of an in-process one — needed only to run
# more than one channel instance (e.g. a webapp alongside the Telegram bot).
# May point at the same Valkey as the router (keys are prefixed). Unset =
# in-process lock, correct for a single channel instance.
# SUITE_VALKEY_URL=redis://localhost:6379/1
# Agents a user may hand the conversation to via /delegate <id> (the l1
# specialists). JSON list; defaults to the three l1 agents.
# SUITE_DELEGATABLE_AGENTS=["research","computer_use","deep_reasoning"]

# --- user_config defaults (seeded per user at registration; tunable via /config) ---
# SUITE_DEFAULT_TIMEZONE=UTC
# SUITE_DEFAULT_LANGUAGE=en
# SUITE_DEFAULT_MAX_CONTEXT_TOKEN_LIMIT=120000      # soft summarization trigger
# Router preset names per tier, seeded into a new user's `user_config` at
# registration (change a user's tiers later from chat, or these defaults to
# retarget new users). Each must name a preset the router has seeded — e.g.
# the friendly tier aliases `gemini-lite` / `gemini-pro` / `gpt-nano` /
# `gpt-pro` / `claude` / `claude-opus`, or the bare `default`. Embeddings must
# name an embedding preset. Defaults below = the seeded `default` chat model.
# SUITE_DEFAULT_PRESET_PRO=default                  # deep_reasoning   (e.g. claude-opus / gemini-pro)
# SUITE_DEFAULT_PRESET_BALANCED=default             # orchestrator + l1 (e.g. claude / default)
# SUITE_DEFAULT_PRESET_LITE=default                 # summarizer/memory/KB/config/cron (e.g. gemini-lite / gpt-nano)
# SUITE_DEFAULT_PRESET_EMBEDDING=default_embedding  # vector search (must be an embedding preset)

# --- Channel (Telegram) + verbose ---
# SUITE_TELEGRAM_BOT_TOKEN=                          # unset → chatbot connects but won't poll
# SUITE_TELEGRAM_BASE_URL=https://api.telegram.org
# SUITE_TELEGRAM_POLL_TIMEOUT_S=25
# SUITE_DISPATCH_RESULT_TIMEOUT_S=600               # how long the channel awaits a turn (code default 600s)
# SUITE_VERBOSE_DETAIL_CHARS=100                     # verbose progress detail cap (0 = off)

# --- Channel (KakaoTalk) — optional second chatbot channel ---
# Egress-only: the agent PULLS turns from a Cloudflare Queue fed by the
# deploy/kakao-relay Worker; it never opens an inbound port. See
# docs/design/kakao-channel.md and deploy/kakao-relay/README.md.
# REQUIRES SUITE_VALKEY_URL (the deadline/next-touch registry) — set it above.
# The three CF queue vars gate the channel (all unset → nothing runs).
# SUITE_KAKAO_CF_ACCOUNT_ID=                          # Cloudflare account id
# SUITE_KAKAO_CF_QUEUE_ID=                            # the kakao-jobs queue id
# SUITE_KAKAO_CF_API_TOKEN=                           # token scoped to Queues pull+ack
# SUITE_KAKAO_CALLBACK_TTL_S=60                       # Kakao callbackUrl lifetime (verify vs Kakao docs)
# SUITE_KAKAO_CALLBACK_DEADLINE_S=50                  # deliver in-time below this, else park (< the TTL)
# SUITE_KAKAO_CARRY_TTL_S=900                         # how long a parked answer waits for the next touch
# SUITE_KAKAO_MSG_CHAR_LIMIT=1000                     # per-bubble simpleText cap
# Outbound images only (presigned R2); inbound images reuse the router store.
# SUITE_KAKAO_R2_ENDPOINT_URL=                        # e.g. https://<acct>.r2.cloudflarestorage.com
# SUITE_KAKAO_R2_BUCKET=
# SUITE_KAKAO_R2_ACCESS_KEY_ID=
# SUITE_KAKAO_R2_SECRET_ACCESS_KEY=
# SUITE_KAKAO_R2_URL_TTL_S=600                        # presigned image-url lifetime

# --- Vector store + embeddings (shared by knowledge base + memory) ---
# SUITE_LANCE_ROOT=./suite_lance                     # per-user LanceDB root (<root>/<user_id>)
# SUITE_EMBEDDING_DIM=1536                            # MUST match the embedding preset's output
                                                      # width; baked into the LanceDB column at
                                                      # table creation (changing it later needs
                                                      # recreating per-user stores).

# --- Knowledge base ---
# SUITE_KB_MAX_CHUNK_LEN=2000
# SUITE_KB_MIN_CHUNK_LEN=1000
# SUITE_KB_OVERLAP_LEN=100
# SUITE_KB_META_HEAD_CHARS=8000                       # head window fed to metadata LLM-gen
# SUITE_KB_META_TAIL_CHARS=2000                       # tail window for the same

# --- Memory fact-graph ---
# SUITE_MEMORY_RETRIEVE_POOL=50                       # hybrid pool size before recency re-rank
# SUITE_MEMORY_RECONCILE_CANDIDATES=5                 # nearest facts shown to the reconcile call
# SUITE_MEMORY_DECAY_START_DAYS=30
# SUITE_MEMORY_GC_HORIZON_DAYS=100                    # facts unused this long are GC'd
# SUITE_MEMORY_DECAY_FLOOR=0.5
# SUITE_MEMORY_GC_INTERVAL_S=86400                    # background GC sweep period

# --- Sandbox (computer_use bash) ---
# SUITE_SANDBOX_ROOT=/home                            # per-user workspace at <root>/<user_id>
# SUITE_SANDBOX_BASH_TIMEOUT_S=120
# SUITE_SANDBOX_MAX_INLINE_OUTPUT=8000                # larger output is saved to a file instead

# --- Research web tools ---
# SUITE_WEB_SEARCH_BACKEND=searxng                    # searxng (default) | brave | kagi
# SUITE_BRAVE_API_KEY=                                # backend=brave: Brave LLM-Context API token
# SUITE_KAGI_API_KEY=                                 # backend=kagi: FastGPT (search) + Extract (html_fetch)
# SUITE_SEARXNG_URL=                                  # backend=searxng: Brave-API-compatible search; unset → web_search off
# SUITE_WEB_FETCH_MAX_BYTES=52428800                  # 50 MiB download cap
# SUITE_WEB_FETCH_TIMEOUT_S=150
# SUITE_WEB_EXTRACT_FETCH_CHARS=16000                 # html_fetch extract_query: page chars read before distilling
# SUITE_WEB_SEARCH_DEEP=auto                          # SearXNG content ranking: off | auto | always | model (searxng-only)
# SUITE_WEB_DEEP_FETCH_MULTIPLIER=2                   # deep search fetches count*N results, returns top count
# SUITE_WEB_DEEP_MIN_SNIPPET_CHARS=80                 # auto: snippet shorter than this = "thin"
# SUITE_WEB_DEEP_THIN_FRACTION=0.5                    # auto: escalate when >this fraction of snippets are thin
# SUITE_WEB_DEEP_CHUNK_CHARS=2000                     # deep search: max chars per page chunk
# SUITE_WEB_DEEP_TOP_CHUNKS=3                          # deep search: page score = sum of top-N chunk scores squared

# ===========================================================================
# Webapp (WEBAPP_*)  — browser channel web server (bp_agents.agents.webapp)
# ===========================================================================
# The webapp is a standalone process fronted by the edge proxy (served from
# root, never mounted under the router). It also reads SUITE_* (suite DB /
# Valkey) and AGENT_* (router WS URL + its agent invitation).

# --- Required ---
# WEBAPP_SESSION_SECRET=                              # signs the session cookie; fail-fast if unset (run-suite.sh sets an insecure dev value)

# --- Cookie / session ---
# WEBAPP_SESSION_COOKIE_NAME=bp_webapp_session
# WEBAPP_SESSION_COOKIE_MAX_AGE_S=86400
# WEBAPP_SESSION_COOKIE_SECURE=true                   # HTTPS-only; set false for local http://localhost dev
# WEBAPP_SESSION_COOKIE_SAME_SITE=lax                 # lax | strict | none
# WEBAPP_REFRESH_BUFFER_S=30                          # refresh the user's access token this many seconds before expiry

# --- SSO (OIDC) — frontend toggle; the router does the actual OIDC flow ---
# WEBAPP_SSO_ENABLED=false                            # show the "Sign in with SSO" button
# WEBAPP_PUBLIC_BASE_URL=https://app.example.com      # builds the OIDC redirect_uri
#                                                     # (<base>/auth/sso/callback); required when SSO on

# --- Server ---
# WEBAPP_DEPLOYMENT_ENV=dev                           # dev | staging | prod
# WEBAPP_UPSTREAM_TIMEOUT_S=10.0                      # router HTTP client timeout
# WEBAPP_USE_BUILT_CSS=false                          # serve prebuilt /static/tailwind.css instead of the Tailwind CDN (set true in prod after building)
# WEBAPP_BIND_HOST=0.0.0.0                            # container-internal; edge proxy fronts it
# WEBAPP_BIND_PORT=8002
