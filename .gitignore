# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/

# Dependency lockfile — intentionally untracked in this environment
uv.lock

# Environment and secrets
.env
*.pem
*.key

# Generated runtime data
agent_state/
proxyfiles/
.test_proxyfiles/

# Credentials persisted by the SDK on first run
**/credentials.json

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Prod compose env (filled-in copy of deploy/.env.prod.example)
deploy/.env.prod
.env.prod

# Operator custom env injected into router + mcp_bridge (copy of the .example)
deploy/.env.prod.custom

# Operator preset overlay (generated by prod.sh, or a filled-in copy of
# deploy/presets.custom.jsonc.example) + the .generated sibling prod.sh writes
# when it won't clobber a hand-edited overlay.
deploy/presets.custom.jsonc
deploy/presets.custom.jsonc.generated

# Edge Caddyfile generated by scripts/prod.sh (render-caddyfile.sh) per EDGE_MODE.
# The committed deploy/Caddyfile is the localhost default for a bare compose up.
deploy/Caddyfile.generated

# Webapp prod CSS — a build artifact (see bp_agents/agents/webapp/tailwind.config.js)
bp_agents/agents/webapp/static/tailwind.css
