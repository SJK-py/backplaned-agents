# Agent-suite image. One image, many agents — the process selects its
# agent at start via $SUITE_AGENT (e.g. orchestrator, chatbot, memory).
#
# Build (from repo root):  docker build -f Dockerfile.suite -t backplaned-suite:latest .
# Run one agent:           docker run -e SUITE_AGENT=orchestrator ... backplaned-suite
#
# Suite agents hold NO provider / S3 / JWT secrets — they call ctx.llm
# and the router's file endpoints. The suite DB schema is applied once via
# the `suite-migrate` one-shot (alembic -c alembic_suite.ini), never on
# container start, so scaling an agent never races the schema.

# --- Stage 1: build the webapp's Tailwind stylesheet ----------------------
# The webapp agent serves a self-hosted /static/tailwind.css in prod
# (WEBAPP_USE_BUILT_CSS=true) instead of the Tailwind Play CDN — removing an
# unpinned third-party runtime dependency and the permissive CSP its in-page
# JIT compiler forces. Built here so the artifact ships in the final image
# (no Node at runtime). Replicates the documented command in
# webapp/tailwind.config.js (a v3-style config, so tailwindcss is pinned 3.x).
FROM node:20-slim AS css-build
WORKDIR /webapp
COPY bp_agents/agents/webapp/tailwind.config.js ./tailwind.config.js
COPY bp_agents/agents/webapp/static/tailwind.input.css ./static/tailwind.input.css
COPY bp_agents/agents/webapp/templates ./templates
RUN npx --yes tailwindcss@3.4.17 -c tailwind.config.js \
      -i static/tailwind.input.css -o static/tailwind.css --minify

# --- Stage 2: the suite runtime image -------------------------------------
FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    SUITE_AGENT=orchestrator

RUN useradd --create-home --uid 10002 bp
WORKDIR /app

COPY . .
# Drop in the prebuilt stylesheet (a git-ignored artifact built in css-build)
# so a prod webapp runs WEBAPP_USE_BUILT_CSS=true with no Node at runtime.
COPY --from=css-build /webapp/static/tailwind.css \
     bp_agents/agents/webapp/static/tailwind.css
# `suite` brings asyncpg/alembic/sqlalchemy/lancedb/markitdown/croniter;
# `webapp` adds the browser channel's FastAPI/uvicorn/Jinja2 stack (one
# image serves the whole roster, so the webapp agent ships here too). The
# SDK + protocol come with the package. No router/provider extras — agents
# reach the LLM through the router's LlmService.
RUN pip install ".[suite,webapp]"

# Pre-create the mount points for the named volumes (AGENT_STATE_DIR=/state,
# SUITE_LANCE_ROOT=/lancedb) OWNED BY the runtime uid. Docker seeds an empty
# named volume from the image directory's ownership/permissions at first
# mount; without these the volume is created root:root and the non-root `bp`
# user (uid 10002) gets EACCES writing credentials.json → onboard succeeds
# server-side but the credential can't be persisted → the agent re-onboards
# next start → router 409 "already registered" → crash loop.
RUN mkdir -p /state /lancedb && chown 10002:10002 /state /lancedb

# The sandbox agent is the ONE service that runs as root (it needs CAP_SETUID
# to drop each user's bash to a private uid) WITH cap_drop: ALL — so it has no
# CAP_DAC_OVERRIDE and can only write a dir it OWNS. The 10002-owned /state
# above would EACCES it (onboard succeeds server-side but the credential can't
# persist → crash → re-onboard a consumed token → router 403). Give it a
# ROOT-owned 0700 dir instead (its named volume seeds from this mount point).
# 0700 also hides the agent's router token from the per-user uid the untrusted
# bash drops to — they can't even traverse the dir. The sandbox service sets
# AGENT_STATE_DIR=/sandbox-state and mounts its volume here.
RUN mkdir -p /sandbox-state && chmod 700 /sandbox-state

USER bp

# `python -m bp_agents.agents.<name>` is the per-agent entrypoint; the
# agent name is chosen at runtime so one image serves the whole roster.
CMD ["sh", "-c", "python -m bp_agents.agents.$SUITE_AGENT"]
