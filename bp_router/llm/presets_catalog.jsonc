// bp_router — built-in LLM preset catalogue.
//
// Source of truth for catalogue-managed presets. These are RE-SYNCED into the
// `llm_presets` table on EVERY router startup: each is upserted and marked
// `managed`, and any managed preset dropped from this file is pruned. It is
// also the in-memory fallback before the DB load. Admin-created presets (added
// via the webUI / admin API) are never touched by the sync.
//
// ── PINNED-FIELD RE-SYNC: only the fields you list here are overwritten ─────
// The re-sync overwrites ONLY the fields a preset entry actually LISTS; any
// field you OMIT is left to operator control (whatever the admin UI / DB
// holds survives the re-sync). So a field present here is "pinned" to the
// catalogue (re-applied every boot); a field absent here is operator-owned.
// That is why most entries below carry only provider / concrete_model /
// api_key_ref — the model identity + credential are pinned, while sampling
// defaults, the tier gate (`min_user_level`), description, etc. are left for
// operators to set durably in the admin UI. On a preset's FIRST creation,
// omitted fields take their defaults (see the `Preset` dataclass). To pin a
// field instead, just add it to the entry. (An explicit JSON `null` counts as
// present → pins the column to NULL.)
//
// This file is JSONC: `//` line comments and `/* ... */` block comments are
// allowed (and stripped before parsing); trailing commas are NOT. Point a
// deployment at a different copy via `ROUTER_LLM_PRESET_CATALOG_PATH`.
//
// Each entry mirrors the `Preset` dataclass (bp_router/llm/presets.py).
//   Required: name, provider, concrete_model
//   Credential: api_key_ref OR inline api_key (both default ""; a keyless
//             local endpoint needs neither, an empty ref calls 401)
//   Optional (omit unless you want to PIN it): description,
//             min_user_level (default "*"), default_temperature,
//             default_max_tokens, default_provider_options, base_url,
//             fallback_preset, max_retries
//
// NAMING: preset `name` must match ^[a-z][a-z0-9_-]{0,63}$ (the DB CHECK
// constraint) — so dots are NOT allowed and versions use `-` (e.g.
// `gemini-2-5-pro`). `concrete_model` is the real upstream identifier the
// provider SDK sees and KEEPS its dotted form (e.g. `gemini-2.5-pro`).
[
  // ===================== Gemini family =====================
  {
    "name": "default",
    "provider": "gemini",
    "concrete_model": "gemini-3.5-flash",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  {
    "name": "default_embedding",
    "provider": "gemini",
    "concrete_model": "gemini-embedding-2",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  {
    "name": "gemini",
    "provider": "gemini",
    "concrete_model": "gemini-3.5-flash",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  {
    "name": "gemini-2-5-pro",
    "provider": "gemini",
    "concrete_model": "gemini-2.5-pro",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  {
    "name": "gemini-3-5-flash",
    "provider": "gemini",
    "concrete_model": "gemini-3.5-flash",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  {
    "name": "gemini-3-1-flash-lite",
    "provider": "gemini",
    "concrete_model": "gemini-3.1-flash-lite",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  {
    "name": "gemini-3-1-pro",
    "provider": "gemini",
    "concrete_model": "gemini-3.1-pro-preview",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  // Friendly tier aliases (point at the current lite / pro Gemini models).
  {
    "name": "gemini-lite",
    "provider": "gemini",
    "concrete_model": "gemini-3.1-flash-lite",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  {
    "name": "gemini-pro",
    "provider": "gemini",
    "concrete_model": "gemini-3.1-pro-preview",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  // Gemini embeddings ride the same provider adapter — its `embed()` uses
  // `concrete_model`, so no separate embeddings provider is needed. The output
  // vector width is NOT pinned here: with no `output_dimensionality` in
  // provider_options the model emits its native dimension. The deployment must
  // set SUITE_EMBEDDING_DIM to match (scripts/prod.sh derives it per provider).
  {
    "name": "gemini-embedding-2",
    "provider": "gemini",
    "concrete_model": "gemini-embedding-2",
    "api_key_ref": "env://GEMINI_API_KEY"
  },

  // ===================== Anthropic / Claude family =====================
  {
    "name": "claude",
    "provider": "anthropic",
    "concrete_model": "claude-sonnet-4-6",
    "api_key_ref": "env://ANTHROPIC_API_KEY"
  },
  {
