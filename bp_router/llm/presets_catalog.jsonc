  // ===================== OpenAI embeddings (separate adapter) =====================
  {
    "name": "text-embedding-3-small",
    "provider": "openai-embeddings",
    "concrete_model": "text-embedding-3-small",
    "api_key_ref": "env://OPENAI_API_KEY"
