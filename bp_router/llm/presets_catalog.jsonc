// bp_router — built-in LLM preset catalogue.
//
// Source of truth for catalogue-managed presets. These are RE-SYNCED into the
// `llm_presets` table on EVERY router startup: each is upserted and marked
// `managed`, and any managed preset dropped from this file is pruned. It is
// also the in-memory fallback before the DB load. Admin-created presets (added
// via the webUI / admin API) are never touched by the sync.
//
// ── PINNED-FIELD RE-SYNC: only the fields you list here are overwritten ─────
// The re-sync overwrites ONLY the fields a preset entry actually LISTS; any
// field you OMIT is left to operator control (whatever the admin UI / DB
// holds survives the re-sync). So a field present here is "pinned" to the
// catalogue (re-applied every boot); a field absent here is operator-owned.
// That is why most entries below carry only provider / concrete_model /
// api_key_ref — the model identity + credential are pinned, while sampling
// defaults, the tier gate (`min_user_level`), description, etc. are left for
// operators to set durably in the admin UI. On a preset's FIRST creation,
// omitted fields take their defaults (see the `Preset` dataclass). To pin a
// field instead, just add it to the entry. (An explicit JSON `null` counts as
// present → pins the column to NULL.)
//
// This file is JSONC: `//` line comments and `/* ... */` block comments are
// allowed (and stripped before parsing); trailing commas are NOT. Point a
// deployment at a different copy via `ROUTER_LLM_PRESET_CATALOG_PATH`.
//
// Each entry mirrors the `Preset` dataclass (bp_router/llm/presets.py).
//   Required: name, provider, concrete_model
//   Credential: api_key_ref OR inline api_key (both default ""; a keyless
//             local endpoint needs neither, an empty ref calls 401)
//   Optional (omit unless you want to PIN it): description,
//             min_user_level (default "*"), default_temperature,
//             default_max_tokens, default_provider_options, base_url,
//             fallback_preset, max_retries
//
// NAMING: preset `name` must match ^[a-z][a-z0-9_-]{0,63}$ (the DB CHECK
// constraint) — so dots are NOT allowed and versions use `-` (e.g.
// `gemini-2-5-pro`). `concrete_model` is the real upstream identifier the
// provider SDK sees and KEEPS its dotted form (e.g. `gemini-2.5-pro`).
[
  // ===================== Gemini family =====================
  {
    "name": "default",
    "provider": "gemini",
    "concrete_model": "gemini-3.5-flash",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  {
    "name": "default_embedding",
    "provider": "gemini",
    "concrete_model": "gemini-embedding-2",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  {
    "name": "gemini",
    "provider": "gemini",
    "concrete_model": "gemini-3.5-flash",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  {
    "name": "gemini-2-5-pro",
    "provider": "gemini",
    "concrete_model": "gemini-2.5-pro",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  {
    "name": "gemini-3-5-flash",
    "provider": "gemini",
    "concrete_model": "gemini-3.5-flash",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  {
    "name": "gemini-3-1-flash-lite",
    "provider": "gemini",
    "concrete_model": "gemini-3.1-flash-lite",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  {
    "name": "gemini-3-1-pro",
    "provider": "gemini",
    "concrete_model": "gemini-3.1-pro-preview",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  // Friendly tier aliases (point at the current lite / pro Gemini models).
  {
    "name": "gemini-lite",
    "provider": "gemini",
    "concrete_model": "gemini-3.1-flash-lite",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  {
    "name": "gemini-pro",
    "provider": "gemini",
    "concrete_model": "gemini-3.1-pro-preview",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  // Gemini embeddings ride the same provider adapter — its `embed()` uses
  // `concrete_model`, so no separate embeddings provider is needed. The output
  // vector width is NOT pinned here: with no `output_dimensionality` in
  // provider_options the model emits its native dimension. A deployment pins a
  // width on `default_embedding` via the overlay and matches SUITE_EMBEDDING_DIM
  // to it — scripts/prod.sh asks for the width and writes both.
  {
    "name": "gemini-embedding-2",
    "provider": "gemini",
    "concrete_model": "gemini-embedding-2",
    "api_key_ref": "env://GEMINI_API_KEY"
  },
  // Friendly embedding alias (points at the current Gemini embedding model).
  // scripts/prod.sh reads this preset's model when generating default_embedding.
  {
    "name": "gemini-embedding",
    "provider": "gemini",
    "concrete_model": "gemini-embedding-2",
    "api_key_ref": "env://GEMINI_API_KEY"
  },

  // ===================== Anthropic / Claude family =====================
  {
    "name": "claude",
    "provider": "anthropic",
    "concrete_model": "claude-sonnet-4-6",
    "api_key_ref": "env://ANTHROPIC_API_KEY"
  },
  {
    "name": "claude-opus",
    "provider": "anthropic",
    "concrete_model": "claude-opus-4-8",
    "api_key_ref": "env://ANTHROPIC_API_KEY"
  },
  {
    "name": "claude-opus-4-8",
    "provider": "anthropic",
    "concrete_model": "claude-opus-4-8",
    "api_key_ref": "env://ANTHROPIC_API_KEY"
  },
  {
    "name": "claude-sonnet",
    "provider": "anthropic",
    "concrete_model": "claude-sonnet-4-6",
    "api_key_ref": "env://ANTHROPIC_API_KEY"
  },
  {
    "name": "claude-sonnet-4-6",
    "provider": "anthropic",
    "concrete_model": "claude-sonnet-4-6",
    "api_key_ref": "env://ANTHROPIC_API_KEY"
  },
  {
    "name": "claude-haiku",
    "provider": "anthropic",
    "concrete_model": "claude-haiku-4-5",
    "api_key_ref": "env://ANTHROPIC_API_KEY"
  },
  {
    "name": "claude-haiku-4-5",
    "provider": "anthropic",
    "concrete_model": "claude-haiku-4-5",
    "api_key_ref": "env://ANTHROPIC_API_KEY"
  },

  // ===================== OpenAI / GPT family =====================
  {
    "name": "openai",
    "provider": "openai",
    "concrete_model": "gpt-5.5",
    "api_key_ref": "env://OPENAI_API_KEY"
  },
  {
    "name": "gpt",
    "provider": "openai",
    "concrete_model": "gpt-5.5",
    "api_key_ref": "env://OPENAI_API_KEY"
  },
  {
    "name": "gpt-5-5",
    "provider": "openai",
    "concrete_model": "gpt-5.5",
    "api_key_ref": "env://OPENAI_API_KEY"
  },
  {
    "name": "gpt-5-5-pro",
    "provider": "openai",
    "concrete_model": "gpt-5.5-pro",
    "api_key_ref": "env://OPENAI_API_KEY"
  },
  {
    "name": "gpt-5-4",
    "provider": "openai",
    "concrete_model": "gpt-5.4",
    "api_key_ref": "env://OPENAI_API_KEY"
  },
  {
    "name": "gpt-5-4-mini",
    "provider": "openai",
    "concrete_model": "gpt-5.4-mini",
    "api_key_ref": "env://OPENAI_API_KEY"
  },
  {
    "name": "gpt-5-4-nano",
    "provider": "openai",
    "concrete_model": "gpt-5.4-nano",
    "api_key_ref": "env://OPENAI_API_KEY"
  },
  {
    "name": "gpt-5",
    "provider": "openai",
    "concrete_model": "gpt-5",
    "api_key_ref": "env://OPENAI_API_KEY"
  },
  {
    "name": "gpt-5-mini",
    "provider": "openai",
    "concrete_model": "gpt-5-mini",
    "api_key_ref": "env://OPENAI_API_KEY"
  },
  {
    "name": "gpt-5-nano",
    "provider": "openai",
    "concrete_model": "gpt-5-nano",
    "api_key_ref": "env://OPENAI_API_KEY"
  },
  {
    "name": "gpt-4-1",
    "provider": "openai",
    "concrete_model": "gpt-4.1",
    "api_key_ref": "env://OPENAI_API_KEY"
  },
  // Friendly tier aliases (point at the current nano / pro GPT models).
  {
    "name": "gpt-nano",
    "provider": "openai",
    "concrete_model": "gpt-5.4-nano",
    "api_key_ref": "env://OPENAI_API_KEY"
  },
  {
    "name": "gpt-pro",
    "provider": "openai",
    "concrete_model": "gpt-5.5-pro",
    "api_key_ref": "env://OPENAI_API_KEY"
  },

  // ===================== OpenAI embeddings (separate adapter) =====================
  {
    "name": "text-embedding-3-small",
    "provider": "openai-embeddings",
    "concrete_model": "text-embedding-3-small",
    "api_key_ref": "env://OPENAI_API_KEY"
  },
  // Friendly embedding alias (points at the current OpenAI embedding model).
  // scripts/prod.sh reads this preset's model when generating default_embedding
  // (also the embedding backend for an Anthropic deploy — no Anthropic embeds).
  {
    "name": "gpt-embedding",
    "provider": "openai-embeddings",
    "concrete_model": "text-embedding-3-small",
    "api_key_ref": "env://OPENAI_API_KEY"
  },
  {
    "name": "text-embedding-3-large",
    "provider": "openai-embeddings",
    "concrete_model": "text-embedding-3-large",
    "api_key_ref": "env://OPENAI_API_KEY"
  }

  // ===================== OpenAI-compatible endpoints =====================
  // Any Chat Completions endpoint (vLLM, SGLang, LM Studio, llama.cpp-server,
  // Friendli, OpenRouter, …) rides the `openai-compatible` provider — set
  // `base_url` to the endpoint and point `api_key_ref` at its key (or omit
  // both for a keyless local server). No catalogue entry ships by default;
  // operators add one via the admin UI or a deployment overlay.
  //
  // EXTRA REQUEST KNOBS (`extra_body`): unlike the native gemini/anthropic/
  // openai providers, this provider has no first-class reasoning toggle. The
  // adapter passes a top-level set of sampling kwargs through, and forwards
  // ANYTHING under a special `extra_body` key to the upstream VERBATIM. That
  // is the escape hatch for server-specific options the OpenAI schema doesn't
  // name — e.g. enabling a model's thinking mode and splitting reasoning out
  // of `content`. Put them in `default_provider_options.extra_body`:
  //
  //   {
  //     "name": "friendli-qwen",
  //     "provider": "openai-compatible",
  //     "concrete_model": "<model-id>",
  //     "base_url": "https://api.friendli.ai/serverless/v1",
  //     "api_key_ref": "env://FRIENDLI_TOKEN",
  //     "default_provider_options": {
  //       "extra_body": {
  //         "parse_reasoning": true,
  //         "chat_template_kwargs": { "enable_thinking": true }
  //       }
  //     }
  //   }
  //
  // REASONING OUTPUT: when the server returns reasoning SEPARATELY from the
  // answer — `message.reasoning_content` (DeepSeek/vLLM/SGLang/Friendli with
  // `parse_reasoning`) or `message.reasoning` (OpenRouter & gateways) — the
  // adapter surfaces it as the turn's thought summary (and streams it as
  // thought deltas). It is display-only: shown as the "thinking" progress
  // line, never round-tripped back as model input. Reasoning left INLINE in
  // `content` (e.g. raw `<think>…</think>`) is not parsed — enable the
  // server's reasoning parser (above) to split it out.
]
