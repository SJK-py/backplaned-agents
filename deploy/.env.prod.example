# Interpolation vars for docker-compose.prod.yml.
#
# Easiest path — the prod launcher builds a complete file (prompts for the
# few must-provide values, random-generates secrets + invitation tokens) and
# then starts/restarts/stops the stack:
#   scripts/prod.sh
# Or copy this file to deploy/.env.prod and fill it in by hand. Then:
#   docker compose -f docker-compose.prod.yml --env-file deploy/.env.prod up -d
#
# These are COMPOSE interpolation vars (mapped into container env by the
# compose file) — distinct from the repo-root .env.example, which is for
# running `bp-router` from source in dev. NEVER commit a filled-in copy;
# prefer Docker/host secrets in real production. See docs/backplaned/deployment.md.

# Edge / reverse proxy (Caddy). The Caddyfile is GENERATED by scripts/prod.sh
# (scripts/render-caddyfile.sh) for EDGE_MODE and written to CADDYFILE_HOST_PATH
# — set these by running prod.sh, not by hand. EDGE_MODE:
#   domain → router + admin on PUBLIC_DOMAIN, browser channel on WEBAPP_DOMAIN
#            (a SEPARATE identity — the webapp serves from /, which would collide
#            with the router's /admin). localhost / LAN name → internal-CA TLS;
#            a public domain resolving here → automatic Let's Encrypt (80+443 open).
#   ip     → bare-IP LAN identity: router + admin on https://<ip>:ROUTER_HTTPS_PORT
#            (default 443), webapp on its own https://<ip>:WEBAPP_HTTPS_PORT (no DNS
#            for app.<ip>). Always https via Caddy's internal CA (compose publishes
#            both ports — open them).
#   both   → serve a domain AND a bare IP at once (e.g. domain via Cloudflare
#            Tunnel + direct LAN by IP). ROUTER_PUBLIC_URL is the domain.
# See docs/backplaned/deployment.md "Edge / reverse proxy (Caddy)".
EDGE_MODE=domain
CADDYFILE_HOST_PATH=./deploy/Caddyfile.generated
# Domain identity (EDGE_MODE=domain|both):
PUBLIC_DOMAIN=example.com
WEBAPP_DOMAIN=app.example.com
# Scheme Caddy serves at the origin. Set `http` when TLS is terminated UPSTREAM
# (Cloudflare Tunnel, external LB) — Caddy then serves plain HTTP and disables
# automatic HTTPS. Public scheme stays https, so nothing else changes. Default
# https. See docs/backplaned/deployment.md.
# EDGE_SCHEME=http
# Bare-IP identity (EDGE_MODE=ip|both) — always https via Caddy's internal CA.
# The router/admin and webapp each get their own published https port; the two
# must differ. The router default (443) shares the existing 443 listener.
# PUBLIC_IP=192.168.1.50
# ROUTER_HTTPS_PORT=443
# WEBAPP_HTTPS_PORT=8443
# Canonical PUBLIC origin (always https; the domain when present, else the IP).
ROUTER_PUBLIC_URL=https://example.com

# --- Postgres (router + suite DBs share this server) ---
PG_USER=postgres
PG_PASSWORD=
# NOTE: currently UNUSED. The suite services connect to the bp_suite
# database as the postgres superuser (PG_USER/PG_PASSWORD), not as a
# dedicated bp_suite role. This var (and the bp_suite role seeded by
# deploy/postgres-init/*.sql) are reserved for a future least-privilege
# wiring; leave blank until that lands. (Was previously documented as
# "MUST match postgres-init" — that was never true: init SQL doesn't
# interpolate env, and nothing connects as the role.)
SUITE_DB_PASSWORD=

# --- Router secrets (generate each: openssl rand -base64 32) ---
ROUTER_JWT_SECRET=
ROUTER_ADMIN_SESSION_SECRET=
ROUTER_METRICS_TOKEN=

# --- Webapp (browser channel) — signs the user session cookie ---
WEBAPP_SESSION_SECRET=

# --- MCP bridge (service_mcp) — set to run the bridge (prod.sh auto-adds
# `--profile mcp` when this is set). The router seeds it as the bridge's
# refresh-token credential; the mcp_bridge service presents the same value.
# Leave empty to not run the bridge. ---
MCP_BRIDGE_SECRET=

# First-boot admin (idempotent seed; use a real-looking domain).
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=

# --- Object store (SeaweedFS / S3) ---
S3_BUCKET=bp-files
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- LLM provider keys (resolved by a preset's api_key_ref) ---
GEMINI_API_KEY=

# Generic key slots for custom/self-hosted LLM providers. Set a value here and
# reference it from a preset's api_key_ref (env://CUSTOM_LLM_API_KEY_1, ...) in
# the admin webUI or deploy/presets.custom.jsonc — no docker-compose edit
# needed (these are already passed into the router container). Leave empty if
# unused.
CUSTOM_LLM_API_KEY_1=
CUSTOM_LLM_API_KEY_2=
CUSTOM_LLM_API_KEY_3=

# --- Agent suite ---
# Embedding vector length for the knowledge_base + memory LanceDB stores. MUST
# match the width the `default_embedding` preset emits. prod.sh asks for this
# value, PINS it on default_embedding in deploy/presets.custom.jsonc (Gemini
# `output_dimensionality` / OpenAI `dimensions`) so the model emits exactly this
# width, and writes the same number here — so the two can't drift. It's baked
# into the LanceDB table schema on first write and frozen for the life of the
# lancedb_data volume — changing it later needs a volume reset.
# SUITE_EMBEDDING_DIM=1536

# Per-tier user-selectable model presets. JSON arrays of preset names (from the
# admin LLM-preset catalog) a user may switch their OWN tier to, via /config or
# the webapp Settings page. Empty (default) → the tier's model is shown but not
# user-changeable. Use VALID JSON (not CSV). Examples:
#   SUITE_SELECTABLE_PRESETS_PRO=["gpt-pro","claude-opus","gemini-pro"]
#   SUITE_SELECTABLE_PRESETS_BALANCED=["default","claude","gpt"]
#   SUITE_SELECTABLE_PRESETS_LITE=["lite","gemini-lite","gpt-nano"]
# SUITE_SELECTABLE_PRESETS_PRO=[]
# SUITE_SELECTABLE_PRESETS_BALANCED=[]
# SUITE_SELECTABLE_PRESETS_LITE=[]

# Vision sidecar — let a TEXT-ONLY chat preset read image/PDF files via a
# separate multimodal preset. Set the vision preset name AND list the presets
# you've declared text-only; then read_file routes image/PDF reads through the
# vision preset (returning text), so the main reasoning model needn't be
# multimodal. Both empty (default) → no sidecar (the agent's own model reads
# files and must itself accept images). TEXT_ONLY uses VALID JSON (not CSV).
# SUITE_DEFAULT_PRESET_MULTIMODAL=          # e.g. gemini-pro / gpt-pro (image-capable)
# SUITE_TEXT_ONLY_PRESETS=[]                # e.g. ["gpt-nano","my-text-only-preset"]

# Telegram bot token for the chatbot gateway (from @BotFather).
SUITE_TELEGRAM_BOT_TOKEN=

# Suite Valkey. docker-compose.prod.yml already defaults this to the
# in-cluster valkey (redis://valkey:6379/1) for the chatbot + webapp — that's
# the distributed per-session lock AND the KakaoTalk deadline/next-touch
# registry. Valkey is Valkey-wire-compatible, so the URL scheme stays redis://;
# only set it here to point at a DIFFERENT server (e.g. external/managed Valkey
# or Valkey); leave it unset to use the bundled one.
# SUITE_VALKEY_URL=redis://valkey:6379/1

# KakaoTalk channel (optional, second chatbot channel). Egress-only: the
# agent PULLS turns from a Cloudflare Queue fed by the deploy/kakao-relay
# Worker (deployed separately with wrangler — see deploy/kakao-relay/README.md).
# Leave the CF vars empty to disable.
SUITE_KAKAO_CF_ACCOUNT_ID=
SUITE_KAKAO_CF_QUEUE_ID=
SUITE_KAKAO_CF_API_TOKEN=
# Outbound KakaoTalk images (optional, presigned R2). Inbound images reuse
# the router file store, so these are only needed to SEND images.
SUITE_KAKAO_R2_ENDPOINT_URL=
SUITE_KAKAO_R2_BUCKET=
SUITE_KAKAO_R2_ACCESS_KEY_ID=
SUITE_KAKAO_R2_SECRET_ACCESS_KEY=

# One invitation token per agent. You SET these (no mint -> paste round-trip):
# POST /v1/admin/invitations accepts a caller-supplied token.
#   1. generate:   scripts/register-invitations.sh --gen >> deploy/.env.prod
#   2. once the router is up, register the same values:
#      ROUTER_URL=https://your.domain scripts/register-invitations.sh deploy/.env.prod
# The chatbot's is registered with provisions_service_user=true automatically.
# CHATBOT_INVITATION=
# WEBAPP_INVITATION=
# ORCHESTRATOR_INVITATION=
# HISTORY_SUMMARIZER_INVITATION=
# MEMORY_INVITATION=
# KNOWLEDGE_BASE_INVITATION=
# MD_CONVERTER_INVITATION=
# CONFIG_INVITATION=
# DEEP_REASONING_INVITATION=
# RESEARCH_INVITATION=
# COMPUTER_USE_INVITATION=
# SANDBOX_INVITATION=

# Web search for the research agent (prod.sh asks this).
# Backend selector: searxng (default) | brave | kagi | exa. brave/kagi/exa use
# their API key below; if the key is unset the agent falls back to SearXNG.
# SUITE_WEB_SEARCH_BACKEND=searxng
# SUITE_BRAVE_API_KEY=                  # backend=brave: Brave LLM-Context API token
# SUITE_KAGI_API_KEY=                   # backend=kagi: FastGPT + Extract API token
# SUITE_EXA_API_KEY=                    # backend=exa: neural /search + /contents (html_fetch)
# SUITE_EXA_SEARCH_TYPE=auto            # backend=exa: auto (default) | fast | instant
# SearXNG endpoint (backend=searxng). Set to the bundled SearXNG
# (http://searxng:8080 — also deploy with `--profile search`), an external
# SearXNG URL, or leave empty to run research without web search.
# SUITE_SEARXNG_URL=
# secret_key for the bundled SearXNG (compose passes it through; only used by
# the `search` profile). prod.sh generates one. The bundled instance also
# mounts deploy/searxng/settings.yml to enable the json format + GET method
# web_search needs — the stock image defaults to html/POST and 403s otherwise.
# SEARXNG_SECRET=

# SearXNG content ranking (searxng backend only; Brave/Kagi ignore it — their
# snippets are already strong). SearXNG only relays thin upstream snippets, so
# deep search can instead fetch the top results, embed their content, and rank
# pages by relevance. Policy: off | auto | always | model. `auto` (default)
# escalates only when the snippets look too thin to choose on; `model` also
# exposes a `deep_web_search` tool the research model can pick per query.
# SUITE_WEB_SEARCH_DEEP=auto
# SUITE_WEB_DEEP_FETCH_MULTIPLIER=2      # fetch count*N results, return top count
# SUITE_WEB_DEEP_MIN_SNIPPET_CHARS=80    # auto: snippet shorter than this = "thin"
# SUITE_WEB_DEEP_THIN_FRACTION=0.5       # auto: escalate when >this fraction are thin
# SUITE_WEB_DEEP_CHUNK_CHARS=2000        # max chars per page chunk
# SUITE_WEB_DEEP_TOP_CHUNKS=3            # page score = sum of top-N chunk scores squared

# html_fetch query-focused distillation: when the research agent passes an
# extract_query, how many chars of each page to read before distilling on the
# lite preset (also caps each page fetched by deep search above).
# SUITE_WEB_EXTRACT_FETCH_CHARS=16000

# md_converter LLM-vision OCR (markitdown-ocr plugin). When KEY + MODEL are
# both set, md_converter.convert OCRs images embedded in PDF/DOCX/PPTX/XLSX
# files (and full pages of scanned PDFs) via a vision model. This is a
# DEDICATED OpenAI-compatible provider, separate from the router's presets
# (MarkItDown needs a synchronous client). Leave unset to disable (image
# handling stays metadata-only, exactly as before).
# SUITE_MD_OCR_API_KEY=                  # required to enable OCR
# SUITE_MD_OCR_MODEL=gpt-4o              # required; must accept image inputs
# SUITE_MD_OCR_BASE_URL=                 # optional: OpenAI-compatible vision endpoint (NOT Anthropic)
# SUITE_MD_OCR_PROMPT=                   # optional: override extraction prompt
# OCR makes a synchronous vision call PER embedded image/page via the OpenAI
# Chat Completions API. The SDK default (600s × 2 retries) lets one slow or
# unreachable/incompatible endpoint hang the whole conversion silently — these
# keep a bad OCR call failing fast. The endpoint MUST be OpenAI-compatible
# (image_url); an Anthropic-shaped backend will not work for OCR.
# SUITE_MD_OCR_TIMEOUT_S=60              # per-image OCR request timeout
# SUITE_MD_OCR_MAX_RETRIES=1             # retries per failed OCR request

# md_converter conversion isolation. Each file→Markdown conversion runs in a
# bounded child process so a pathological document (a huge or malformed PDF
# that spins pdfminer or balloons memory) fails one task cleanly instead of
# OOM-killing the agent with no log and no result. Defaults are sensible; tune
# only if you convert unusually large documents.
# SUITE_MD_CONVERT_TIMEOUT_S=120         # per-conversion wall-clock budget
# SUITE_MD_CONVERT_MEM_LIMIT_MB=0        # optional RLIMIT_AS cap (0=off; rely on mem_limit)
# MD_CONVERTER_MEM_LIMIT=2g              # container memory cap (compose mem_limit)

# --- OIDC / SSO for the webapp (optional; OFF by default) ---
# See docs/design/oidc-webapp.md. The router is the OIDC relying party; the
# webapp shows a "Sign in with SSO" button. The single switch OIDC_ENABLED
# drives both. When enabling, set the issuer + client credentials below and
# register the redirect URI at your OP. The redirect allowlist + the webapp's
# public base URL default to https://${WEBAPP_DOMAIN}(/auth/sso/callback), so
# they match out-of-the-box in domain mode — override only for a non-default
# topology (e.g. bare-IP, where you'd set OIDC_ALLOWED_REDIRECT_URIS and
# WEBAPP_PUBLIC_BASE_URL to the webapp's https://<ip>:<port> origin).
# OIDC_ENABLED=true
# OIDC_ISSUER=https://auth.example.com        # OP base; discovery at <issuer>/.well-known/openid-configuration
# OIDC_CLIENT_ID=backplaned-webapp
# OIDC_CLIENT_SECRET=                          # confidential-client secret (or a secret_ref, e.g. env://VAR)
# OIDC_SCOPES=openid email profile groups
# OIDC_ALLOWED_REDIRECT_URIS=["https://app.example.com/auth/sso/callback"]
# WEBAPP_PUBLIC_BASE_URL=https://app.example.com
# Make the webapp SSO-only: hide/disable password login, /register and
# /set-password. Requires SSO enabled (else there'd be no way to sign in).
# WEBAPP_PASSWORD_LOGIN_ENABLED=false
# --- Provisioning policy (first SSO login) ---
# OIDC_JIT_PROVISIONING=true                   # create users on first login; false = only pre-linked subjects
# OIDC_DEFAULT_LEVEL=tier1                     # level when no group mapping matches
# OIDC_GROUP_TO_LEVEL={"admins":"admin","staff":"tier0"}   # IdP group → router level
# OIDC_ALLOWED_GROUPS=[]                        # non-empty → user MUST be in one of these groups
# OIDC_AUTO_LINK_BY_VERIFIED_EMAIL=false        # DANGER — see design doc §6 (single trust domain only)
