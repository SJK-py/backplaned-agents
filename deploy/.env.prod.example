# Interpolation vars for docker-compose.prod.yml. Copy to deploy/.env.prod
# and fill in, then:
#   docker compose -f docker-compose.prod.yml --env-file deploy/.env.prod up -d
#
# These are COMPOSE interpolation vars (mapped into container env by the
# compose file) — distinct from the repo-root .env.example, which is for
# running `bp-router` from source in dev. NEVER commit a filled-in copy;
# prefer Docker/host secrets in real production. See docs/deployment.md.

# Public hostname Caddy serves (auto-TLS). Use localhost for a local trial.
PUBLIC_DOMAIN=example.com

# --- Postgres (router + suite DBs share this server) ---
PG_USER=postgres
PG_PASSWORD=
# Password for the bp_suite role; MUST match deploy/postgres-init/*.sql.
SUITE_DB_PASSWORD=

# --- Router secrets (generate each: openssl rand -base64 32) ---
ROUTER_JWT_SECRET=
ROUTER_ADMIN_SESSION_SECRET=
ROUTER_METRICS_TOKEN=

# First-boot admin (idempotent seed; use a real-looking domain).
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=

# --- Object store (rustfs / S3) ---
S3_BUCKET=bp-files
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- LLM provider keys (resolved by a preset's api_key_ref) ---
GEMINI_API_KEY=

# --- Agent suite ---
# Telegram bot token for the chatbot gateway (from @BotFather).
SUITE_TELEGRAM_BOT_TOKEN=

# One invitation token per agent. You SET these (no mint -> paste round-trip):
# POST /v1/admin/invitations accepts a caller-supplied token.
#   1. generate:   scripts/register-invitations.sh --gen >> deploy/.env.prod
#   2. once the router is up, register the same values:
#      ROUTER_URL=https://your.domain scripts/register-invitations.sh deploy/.env.prod
# The chatbot's is registered with provisions_service_user=true automatically.
# CHATBOT_INVITATION=
# ORCHESTRATOR_INVITATION=
# HISTORY_SUMMARIZER_INVITATION=
# MEMORY_INVITATION=
# KNOWLEDGE_BASE_INVITATION=
# MD_CONVERTER_INVITATION=
# CONFIG_INVITATION=
# DEEP_REASONING_INVITATION=
# RESEARCH_INVITATION=
# COMPUTER_USE_INVITATION=
# SANDBOX_INVITATION=

# Optional: external Brave-API-compatible search (else use the `search` profile).
# SUITE_SEARXNG_URL=
